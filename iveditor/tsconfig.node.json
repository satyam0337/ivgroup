{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noEmit": true,
    "types": ["node", "@wdio/globals/types", "@wdio/mocha-framework", "@wdio/visual-service"]
  },
  "include": ["vite.config.ts", "scripts/**/*.ts", "test/**/*.ts"],
}
